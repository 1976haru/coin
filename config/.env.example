# Agent Trader Crypto OS — 환경변수 템플릿 (체크리스트 #9 Config Layer)
#
# 사용:
#   1. cp config/.env.example .env       (저장소 루트에 .env 작성)
#   2. 실제 값 입력. 본 파일에는 절대 실제 값을 넣지 말 것.
#   3. .env 는 .gitignore 에 포함되어 있으니 커밋되지 않는다.
#
# 환경변수 prefix: AUTOTRADE_   (예: AUTOTRADE_TRADING__MODE)
# nested delimiter: __          (예: AUTOTRADE_BROKER__API_KEY → broker.api_key)
#
# 우선순위: OS env > .env > config/config.yaml > code default.

# ── app ─────────────────────────────────────────────────────────
AUTOTRADE_APP__ENV=local

# ── trading ─────────────────────────────────────────────────────
AUTOTRADE_TRADING__MODE=paper
AUTOTRADE_TRADING__ALLOW_LIVE_TRADING=false
AUTOTRADE_TRADING__REQUIRE_APPROVAL_FOR_LIVE=true

# ── risk ────────────────────────────────────────────────────────
# (대부분은 config.yaml 로 관리 — 환경별 override 가 필요할 때만 채움)
# AUTOTRADE_RISK__MAX_DAILY_LOSS=100000
# AUTOTRADE_RISK__MAX_OPEN_POSITIONS=3
# AUTOTRADE_RISK__EMERGENCY_STOP_ENABLED=true

# ── broker (Secret) ─────────────────────────────────────────────
# 본 단계는 mock/paper 만 사용 — 실거래 키 입력 금지.
AUTOTRADE_BROKER__PROVIDER=mock
AUTOTRADE_BROKER__API_KEY=
AUTOTRADE_BROKER__API_SECRET=
AUTOTRADE_BROKER__ACCOUNT_NO=

# ── database (Secret) ───────────────────────────────────────────
AUTOTRADE_DATABASE__URL=

# ── logging ─────────────────────────────────────────────────────
AUTOTRADE_LOGGING__LEVEL=INFO
AUTOTRADE_LOGGING__JSON=false

# ── feature flags (체크리스트 #10) ──────────────────────────────
# 모든 위험 플래그 default false. true 로 켜도 feature_flags.py 의
# 다중 조건 게이트(mode/allow_live_trading/env)를 추가 통과해야 한다.
AUTOTRADE_FLAGS__ENABLE_LIVE_TRADING=false
AUTOTRADE_FLAGS__ENABLE_AI_EXECUTION=false
AUTOTRADE_FLAGS__ENABLE_CRYPTO_FUTURES_LIVE=false
AUTOTRADE_FLAGS__ENABLE_KIMP_STRATEGY=false
