# Agent Trader Crypto OS v1 — 환경변수 (변수명 전용, 값 비워둠)
# 사용:
#   Copy-Item .env.example .env
#   .env 파일에 실제 값 입력. 절대 git 커밋 금지.

# ── 운용 모드 ─────────────────────────────────────────────────
# SIMULATION | PAPER | LIVE_SHADOW | LIVE_MANUAL_APPROVAL | LIVE_AI_ASSIST | LIVE_AI_EXECUTION
TRADING_MODE=PAPER
DEMO_MODE=true

# ── 위험 Feature Flags (모두 기본 false — 변경 금지) ──────────
ENABLE_LIVE_TRADING=false
ENABLE_AI_EXECUTION=false
ENABLE_CRYPTO_FUTURES_LIVE=false
ENABLE_LIVE_ORDER_SUBMISSION=false
# ENABLE_WITHDRAWAL 은 코드상 영구 false. 환경변수로 켜지지 않음.

# ── 기능 Feature Flags ───────────────────────────────────────
ENABLE_KIMP_STRATEGY=true   # paper-only 의미 — PermissionGate가 모드와 함께 차단
ENABLE_AI_AGENTS=false       # ENABLE 시 LLM 호출
ENABLE_OKX=true
ENABLE_UPBIT=true

# ── 리스크 파라미터 ──────────────────────────────────────────
MAX_ORDER_NOTIONAL_USDT=
DAILY_LOSS_LIMIT_PCT=
MAX_OPEN_POSITIONS=
MAX_LEVERAGE=
MAX_CONSECUTIVE_LOSSES=
RE_ENTRY_COOLDOWN_MIN=
FRESHNESS_THRESHOLD_SEC=

# ── Watchlist / Universe (#14) ──────────────────────────────
# 전체 enabled watchlist 항목 수 상한. 기본 100. list_name 별 cap 과 함께 작동.
WATCHLIST_MAX_ENABLED_TOTAL=

# ── 거래소 API (출금 권한 절대 부여 금지 — #27) ──────────────
# LIVE 키 — TRADING_MODE 가 LIVE_* 일 때만 채움.
# 출금/이체 권한 OFF + IP whitelist 필수. docs/api_key_policy.md 참조.
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSWORD=
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=
# (Binance LIVE 는 #23 후속 LIVE 어댑터 구현 시 추가)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# ── Sandbox / Testnet 키 (#28) ───────────────────────────────
# 거래소가 별도 sandbox 환경을 제공할 때 채움. LIVE 변수와 절대 섞지 말 것.
# docs/sandbox_paper_keys.md 참조.
# Upbit 은 sandbox 미제공 — 슬롯 없음.
OKX_API_KEY_SANDBOX=
OKX_API_SECRET_SANDBOX=
OKX_API_PASSWORD_SANDBOX=
BINANCE_API_KEY_SANDBOX=
BINANCE_API_SECRET_SANDBOX=

# ── 환율 ────────────────────────────────────────────────────
EXCHANGERATE_API_KEY=
USDT_KRW_FALLBACK=

# ── AI ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
AI_MODEL=

# ── 알림 (선택) ────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── 보안 ───────────────────────────────────────────────────
# 운영 시 반드시 추측 어려운 값으로 변경
ADMIN_TOKEN=

# ── DB (체크리스트 #13) ─────────────────────────────────────
# 미설정 시 sqlite:///logs/agent_trader.db 기본값.
# 운영: DATABASE_URL 설정 후 `cd backend && alembic upgrade head` 실행.
DATABASE_URL=
